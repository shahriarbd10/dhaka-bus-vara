PORT=4000
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://username:password@cluster-0-shard-00-00.example.net:27017,cluster-0-shard-00-01.example.net:27017,cluster-0-shard-00-02.example.net:27017/?ssl=true&replicaSet=atlas-xxxxxx-shard-0&authSource=admin&appName=bus-vara
# MONGODB_URI_BACKUP=mongodb+srv://username:password@cluster.example.net/?appName=bus-vara
MAX_UPLOAD_SIZE_MB=12

JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=12h
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
